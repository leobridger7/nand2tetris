/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Or(a= a, b= b, out= x1);
    Nand(a= a, b= b, out= x2);
    And(a= x1, b= x2, out= out);
}